<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Smart Settings Panel</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
body {
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #eef2ff, #f8fafc);
}

.sidebar {
    min-height: 100vh;
    background: #111827;
}
.sidebar a {
    display: block;
    color: white;
    padding: 12px;
    margin: 5px 0;
    border-radius: 8px;
    transition: 0.3s;
}
.sidebar a:hover {
    background: #2563eb;
    transform: translateX(5px);
}

.card {
    border-radius: 15px;
    transition: 0.3s;
}
.card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
}

.nav-link.active {
    font-weight: bold;
    border-bottom: 2px solid white;
}

.dark-mode {
    background: #0f172a !important;
    color: white !important;
}

.toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
}
</style>
</head>

<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
<div class="container-fluid">
<a class="navbar-brand fw-bold" href="#"><i class="bi bi-gear-fill"></i> Smart Panel</a>

<button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
<span class="navbar-toggler-icon"></span>
</button>

<div class="collapse navbar-collapse" id="menu">
<ul class="navbar-nav ms-auto">

<li class="nav-item">
<a class="nav-link active" href="#" onclick="goHome()">Home</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#profileModal">
<i class="bi bi-person-circle"></i> Profile
</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#" onclick="openSettings()">Settings</a>
</li>

</ul>
</div>
</div>
</nav>

<!-- 🔥 HOME SECTION -->
<div id="home" class="p-4 text-center bg-light">
<h2 class="fw-bold">Welcome to Smart Settings Panel</h2>
<p class="text-muted">Manage your account, privacy, security and preferences easily.</p>
<button class="btn btn-primary" onclick="openSettings()">Go to Settings</button>
</div>

<div class="container-fluid">
<div class="row">

<!-- Sidebar -->
<div class="col-md-3 col-lg-2 sidebar text-white p-3">
<h5 class="text-center mb-4">⚙ Menu</h5>
<a href="#account">Account</a>
<a href="#notifications">Notifications</a>
<a href="#privacy">Privacy</a>
<a href="#security">Security</a>
<a href="#appearance">Appearance</a>
</div>

<!-- Content -->
<div class="col-md-9 col-lg-10 p-4">

<!-- Account -->
<div id="account" class="card shadow mb-4">
<div class="card-header bg-primary text-white">Account Settings</div>
<div class="card-body">
<input class="form-control mb-2" type="text" placeholder="Full Name">
<input class="form-control mb-2" type="email" placeholder="Email Address">
<input class="form-control mb-2" type="password" placeholder="Password">
<button class="btn btn-success" onclick="showToast()">Save Changes</button>
</div>
</div>

<!-- Notifications -->
<div id="notifications" class="card shadow mb-4">
<div class="card-header bg-info text-white">Notification Settings</div>
<div class="card-body">
<div class="form-check"><input class="form-check-input" type="checkbox"> Email Alerts</div>
<div class="form-check"><input class="form-check-input" type="checkbox"> SMS Alerts</div>
<div class="form-check"><input class="form-check-input" type="checkbox"> App Alerts</div>
<button class="btn btn-success mt-3" onclick="showToast()">Save</button>
</div>
</div>

<!-- Privacy -->
<div id="privacy" class="card shadow mb-4">
<div class="card-header bg-warning">Privacy Settings</div>
<div class="card-body">
<select class="form-select mb-2">
<option>Public</option>
<option>Private</option>
</select>
<div class="form-check">
<input class="form-check-input" type="checkbox"> Show Email to Others
</div>
<div class="form-check">
<input class="form-check-input" type="checkbox"> Allow Search Engines
</div>
<button class="btn btn-success mt-3" onclick="showToast()">Save</button>
</div>
</div>

<!-- Security -->
<div id="security" class="card shadow mb-4">
<div class="card-header bg-danger text-white">Security</div>
<div class="card-body">
<label>Two Factor Authentication</label>
<select class="form-select mb-2">
<option>Enabled</option>
<option>Disabled</option>
</select>

<label>Login Alerts</label>
<select class="form-select mb-2">
<option>On</option>
<option>Off</option>
</select>

<button class="btn btn-success" onclick="showToast()">Update Security</button>
</div>
</div>

<!-- Appearance -->
<div id="appearance" class="card shadow mb-4">
<div class="card-header bg-secondary text-white">Appearance</div>
<div class="card-body">
<select class="form-select mb-2" id="theme">
<option value="light">Light</option>
<option value="dark">Dark</option>
</select>
<button class="btn btn-dark" onclick="changeTheme()">Apply Theme</button>
</div>
</div>

</div>
</div>
</div>

<!-- Profile Modal -->
<div class="modal fade" id="profileModal">
<div class="modal-dialog modal-dialog-centered">
<div class="modal-content">

<div class="modal-header bg-primary text-white">
<h5 class="modal-title"><i class="bi bi-person-circle"></i> My Profile</h5>
<button class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body text-center">
<div class="position-relative d-inline-block">
<img id="profileImg" src="https://via.placeholder.com/120" class="rounded-circle shadow" width="120">
<label class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle p-2" style="cursor:pointer;">
<i class="bi bi-camera"></i>
<input type="file" hidden onchange="previewImage(event)">
</label>
</div>

<h5 class="mt-3" id="displayName">Your Name</h5>

<input type="text" id="username" class="form-control mb-2" placeholder="Enter Name" oninput="updateName()">
<input type="email" id="useremail" class="form-control mb-2" placeholder="Enter Email">
</div>

<div class="modal-footer">
<button class="btn btn-success" onclick="saveProfile()">Save</button>
</div>

</div>
</div>
</div>

<!-- Toast -->
<div class="toast-container">
<div id="toast" class="toast text-bg-success border-0">
<div class="d-flex">
<div class="toast-body">✅ Saved Successfully!</div>
<button class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
</div>
</div>
</div>

<footer class="bg-dark text-white text-center p-3 mt-3">
© 2026 Smart Panel
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
function showToast() {
    new bootstrap.Toast(document.getElementById('toast')).show();
}

function changeTheme() {
    let theme = document.getElementById("theme").value;
    document.body.classList.toggle("dark-mode", theme === "dark");
}

function saveProfile() {
    localStorage.setItem("name", username.value);
    localStorage.setItem("email", useremail.value);
    showToast();
}

function previewImage(event) {
    let reader = new FileReader();
    reader.onload = () => profileImg.src = reader.result;
    reader.readAsDataURL(event.target.files[0]);
}

function updateName() {
    displayName.innerText = username.value || "Your Name";
}

function goHome() {
    home.scrollIntoView({behavior:"smooth"});
}

function openSettings() {
    account.scrollIntoView({behavior:"smooth"});
}

// Active nav highlight
document.querySelectorAll(".nav-link").forEach(link=>{
    link.addEventListener("click",function(){
        document.querySelectorAll(".nav-link").forEach(l=>l.classList.remove("active"));
        this.classList.add("active");
    });
});

// Load saved data
window.onload = function() {
    username.value = localStorage.getItem("name") || "";
    useremail.value = localStorage.getItem("email") || "";
    displayName.innerText = username.value || "Your Name";
}
</script>

</body>
</html>
